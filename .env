# PDS Error Classifier — Environment Configuration
# Copy this file to .env and fill in your values

# ── Server ──────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── OpenAI ──────────────────────────────────────────
# Required: your OpenAI API key for AI-powered classification
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini         # Cost-efficient; upgrade to gpt-4o for higher accuracy
OPENAI_MAX_TOKENS=500
OPENAI_TEMPERATURE=0.2           # Low temperature = more deterministic classification

# ── Redis ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=                  # Leave blank if no auth
REDIS_TTL_SECONDS=3600           # How long to cache classifications (1 hour default)
REDIS_KEY_PREFIX=pds:error:      # Namespace prefix for all cache keys

# ── Classification ───────────────────────────────────
# If true, unknown errors fall back to AI classification; if false, return generic message
AI_FALLBACK_ENABLED=true
# Minimum confidence score (0–1) to accept an AI classification
AI_CONFIDENCE_THRESHOLD=0.6

# ── Rate Limiting ────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000       # 1-minute window
RATE_LIMIT_MAX_REQUESTS=100      # Max requests per window per IP

# ── Logging ─────────────────────────────────────────
LOG_LEVEL=info                   # error | warn | info | debug
LOG_FORMAT=json                  # json | pretty
