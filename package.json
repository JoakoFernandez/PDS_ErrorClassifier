{
  "name": "pds-error-classifier",
  "version": "1.0.0",
  "description": "PDS Payment Error Classifier Microservice — maps cryptic payment errors to human-friendly messages with AI classification and Redis caching",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "test": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "docs": "typedoc --out docs/api src"
  },
  "dependencies": {
    "express": "^4.18.2",
    "ioredis": "^5.3.2",
    "openai": "^4.28.0",
    "dotenv": "^16.3.1",
    "zod": "^3.22.4",
    "winston": "^3.11.0",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "uuid": "^9.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "setupFiles": ["./jest.setup.js"],
    "testEnvironment": "node",
    "roots": ["<rootDir>/__tests__"],
    "moduleFileExtensions": ["ts", "js", "json"],
    "testMatch": ["**/*.test.ts", "**/*.spec.ts"],
    "collectCoverageFrom": ["src/**/*.ts", "!src/index.ts"]
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/uuid": "^9.0.7",
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "ts-node-dev": "^2.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "@types/jest": "^29.5.11"
  }
}
